{
  "$schema": "https://docs.umbraco.com/umbraco-cms/v/17.latest/extending/customize-the-backoffice/umbraco-package-manifest",
  "name": "uMockingSuite",
  "version": "0.1.0",
  "allowPublicAccess": false,
  "extensions": [
    {
      "type": "workspaceContext",
      "alias": "uMockingSuite.WorkspaceContext.Document",
      "name": "uMockingSuite Document Workspace Context",
      "api": "/App_Plugins/uMockingSuite/umockingsuite-workspace-context.js",
      "conditions": [
        {
          "alias": "Umb.Condition.WorkspaceAlias",
          "match": "Umb.Workspace.Document"
        }
      ]
    }
  ]
}
