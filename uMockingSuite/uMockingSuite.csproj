<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <PackageId>uMockingSuite</PackageId>
    <Version>0.1.0</Version>
    <Authors>Jonny Muir</Authors>
    <Description>AI-powered snarky toast notifications for Umbraco 17. Built at the Manchester Umbraco AI Hackathon to demonstrate how easy it is to integrate the Umbraco AI package into your workflows. A study vehicle for learning Umbraco 17 extension development and AI integration patterns.</Description>
    <PackageTags>umbraco;umbraco-package;umbraco17;ai;backoffice;mocking;hackathon;umbraco-ai</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Copyright>Copyright © 2026 Jonny Muir</Copyright>
    <RepositoryUrl>https://github.com/YOUR-ORG/uMockingSuite</RepositoryUrl>
    <PackageProjectUrl>https://github.com/YOUR-ORG/uMockingSuite</PackageProjectUrl>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Umbraco.Cms" Version="17.3.4">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Umbraco.AI.Core" Version="1.9.0">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <Content Include="App_Plugins\**" CopyToOutputDirectory="Always">
      <Pack>true</Pack>
      <PackagePath>content\App_Plugins\%(RecursiveDir)%(Filename)%(Extension)</PackagePath>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
